APP_APP_NAME=Route Optimization Lab
APP_CORS_ALLOWED_ORIGINS=

# Routing and external data. Put real keys in the hosting dashboard, not in git.
APP_TOMTOM_ENABLED=true
APP_TOMTOM_API_KEY=
APP_TOMTOM_ROUTING_API_KEY=
APP_TOMTOM_SEARCH_API_KEY=
APP_TOMTOM_TRAFFIC_API_KEY=
APP_TOMTOM_INCIDENTS_API_KEY=
APP_OPENROUTESERVICE_ENABLED=false
APP_OPENROUTESERVICE_API_KEY=
APP_OSRM_ENABLED=true
APP_OVERPASS_ENABLED=true

# Demo defaults.
APP_SYNTHETIC_DATA_ENABLED=false
APP_TOLL_ENABLED=false
APP_ROUTE_RUNS_DB_PATH=/tmp/route_runs.db
APP_GA_DEFAULT_POPULATION=64
APP_GA_DEFAULT_GENERATIONS=80
APP_GA_PARALLEL_WORKERS=1
